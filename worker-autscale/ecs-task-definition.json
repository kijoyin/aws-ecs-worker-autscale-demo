{
  "family": "worker-autoscale-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::{account-id}:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::{account-id}:role/workerAutoscaleTaskRole",
  "containerDefinitions": [
    {
      "name": "worker-autoscale",
      "image": "{account-id}.dkr.ecr.{region}.amazonaws.com/worker-autoscale:latest",
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/worker-autoscale",
          "awslogs-region": "{region}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Production"
        },
        {
          "name": "AWS_REGION",
          "value": "{region}"
        },
        {
          "name": "CloudWatch__Namespace",
          "value": "WorkerAutoscale"
        },
        {
          "name": "CloudWatch__ServiceName",
          "value": "WorkerService"
        },
        {
          "name": "MetricsPublishIntervalSeconds",
          "value": "60"
        },
        {
          "name": "BatchSize",
          "value": "100"
        },
        {
          "name": "ProcessingDelayMilliseconds",
          "value": "1000"
        }
      ]
    }
  ]
}
